{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/bun.lock",
      "{workspaceRoot}/tsconfig.base.json"
    ],
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/dist/**",
      "!{projectRoot}/tests/**",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/vitest.config.ts"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}