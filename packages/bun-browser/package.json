{
  "name": "bun-browser",
  "version": "0.0.0",
  "private": true,
  "description": "Bun Core compiled to WebAssembly for browsers, driven by a host JS engine via the JSI bridge.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./kernel": "./src/kernel.ts",
    "./kernel-worker": "./src/kernel-worker.ts",
    "./jsi-host": "./src/jsi-host.ts",
    "./vfs-client": "./src/vfs-client.ts",
    "./protocol": "./src/protocol.ts"
  },
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "scripts": {
    "build:wasm": "cd ../.. && bun scripts/build.ts --target=wasm --wasm_profile=browser_runtime --profile=release",
    "typecheck": "tsc -p .",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/node": "^20.4.10",
    "typescript": "^6.0.0"
  }
}
