{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "harness": ["./src/harness.d.ts"]
    },
    "types": ["vitest/globals", "@types/bun"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "../bun-web-kernel/src/**/*.ts",
    "../bun-web-sw/src/**/*.ts",
    "../bun-web-net/src/**/*.ts",
    "../bun-web-dns/src/**/*.ts",
    "../bun-web-client/src/**/*.ts",
    "../bun-web-proxy-server/src/**/*.ts",
    "../bun-web-shell/src/**/*.ts",
    "../bun-web-transpiler/src/**/*.ts",
    "../bun-web-bundler/src/**/*.ts",
    "../bun-web-sqlite/src/**/*.ts",
    "../bun-web-crypto/src/**/*.ts",
    "../bun-web-vfs/src/**/*.ts",
    "../bun-web-runtime/src/**/*.ts",
    "../bun-web-node/src/**/*.ts",
    "../bun-web-agent/src/**/*.ts",
    "../bun-web-example/src/**/*.ts",
    "../bun-web-compat-registry/src/**/*.ts",
    "../bun-web-hooks/src/**/*.ts",
    "../bun-web-plugin-api/src/**/*.ts",
    "../bun-web-shared/src/**/*.ts",
    "../bun-web-resolver/src/**/*.ts",
    "../bun-web-installer/src/**/*.ts",
    "../bun-web-webapis/src/**/*.ts",
    "vitest.config.ts",
    "tsdown.config.ts"
  ]
}
